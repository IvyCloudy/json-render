{
  "__form": {
    "auth": {
      "bearer": "{{token}}"
    },
    "submit": [
      {
        "label": "Create (JSON)",
        "url": "http://127.0.0.1:39870/echo",
        "method": "POST",
        "headers": {
          "X-Source": "json-render"
        },
        "query": {
          "role": "{{role}}"
        },
        "body": {
          "id": "{{id}}",
          "name": "{{name}}",
          "age": "{{age}}",
          "email": "{{email}}",
          "active": "{{active}}",
          "bio": "{{bio}}"
        },
        "requiredPaths": [
          "name",
          "email"
        ],
        "responsePath": "lastResponse",
        "variant": "primary",
        "timeoutMs": 5000,
        "openUrl": "{{lastResponse.redirect}}"
      },
      {
        "label": "Save Draft",
        "url": "http://127.0.0.1:39870/echo",
        "method": "PUT",
        "variant": "secondary",
        "bodyPath": "name"
      },
      {
        "label": "Slow (6s, will timeout)",
        "url": "http://127.0.0.1:39870/slow?ms=6000",
        "method": "POST",
        "timeoutMs": 2000,
        "variant": "secondary"
      },
      {
        "label": "Force 500",
        "url": "http://127.0.0.1:39870/fail?code=500",
        "method": "POST",
        "variant": "secondary"
      },
      {
        "label": "Upload file",
        "url": "http://127.0.0.1:39870/upload",
        "method": "POST",
        "body": {
          "note": "{{name}}'s avatar",
          "tag": "profile",
          "avatar": {
            "$file": "./sample-avatar.txt",
            "filename": "avatar.txt",
            "contentType": "text/plain"
          }
        },
        "responsePath": "lastUpload",
        "variant": "primary"
      },
      {
        "type": "reset",
        "label": "Reset",
        "variant": "secondary",
        "confirm": "Reset all fields to initial values?"
      },
      {
        "label": "Delete",
        "url": "http://127.0.0.1:39870/echo",
        "method": "DELETE",
        "variant": "danger",
        "confirm": "Delete this record?"
      }
    ]
  },
  "token": "demo-token-xyz",
  "id": "u-1001",
  "role": "admin",
  "name": "Alice",
  "age": 18,
  "email": "alice@example.com",
  "active": true,
  "bio": "A long bio that will be rendered as a textarea because its length exceeds the threshold used by the form view. Edit freely.",
  "lastResponse": {
    "method": "POST",
    "path": "/echo",
    "query": {
      "role": "admin"
    },
    "headers": {
