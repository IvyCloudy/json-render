      ],
      "props": {
        "placeholder": "请输入真实姓名",
        "allowClear": true
      }
    },
    {
      "label": "用户角色",
      "keyName": "role",
      "keyValue": "admin",
      "component": "Select",
      "col": {
        "span": 12
      },
      "rules": [
        {
          "required": true,
          "message": "请选择角色"
        }
      ],
      "options": [
        {
          "label": "管理员",
          "value": "admin"
        },
        {
          "label": "开发者",
          "value": "developer"
        },
        {
          "label": "运营",
          "value": "operator"
        }
      ],
      "props": {
        "placeholder": "分配权限角色"
      }
    },
    {
      "label": "年龄",
      "keyName": "age",
      "keyValue": 18,
      "component": "InputNumber",
      "col": {
        "span": 8
      },
      "props": {
        "min": 1,
        "max": 120,
        "style": {
          "width": "100%"
        }
      }
    },
    {
      "label": "账户邮箱",
      "keyName": "email",
