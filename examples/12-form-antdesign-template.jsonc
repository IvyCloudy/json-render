      "component": "Input",
      "col": {
        "span": 16
      },
      "rules": [
        {
          "type": "email",
          "message": "请输入有效的邮箱地址"
        }
      ],
      "props": {
        "placeholder": "example@domain.com"
      }
    },
    {
      "label": "出生日期",
      "keyName": "birthday",
      "keyValue": "2005-05-20",
      "component": "DatePicker",
      "col": {
        "span": 12
      },
      "props": {
        "format": "YYYY-MM-DD",
        "style": {
          "width": "100%"
        }
      }
    },
    {
      "label": "账户激活状态",
      "keyName": "active",
      "keyValue": true,
      "component": "Switch",
      "col": {
        "span": 12
      },
      "valuePropName": "checked",
      "props": {
        "checkedChildren": "已开启",
        "unCheckedChildren": "已禁用"
      }
    },
    {
      "label": "个人简介",
      "keyName": "bio",
      "keyValue": "A long bio that will be rendered as a textarea...",
      "component": "Input.TextArea",
      "col": {
        "span": 24
      },
      "props": {
        "rows": 4,
        "showCount": true,
        "maxLength": 500,
        "placeholder": "请输入详细的个人描述"
      }
    },
    {
      "label": "性别",
      "keyName": "gender",
      "keyValue": "female",
      "component": "Radio.Group",
      "col": {
        "span": 24
      },
      "options": [
        {
          "label": "男",
          "value": "male"
        },
        {
          "label": "女",
          "value": "female"
        },
        {
          "label": "保密",
          "value": "secret"
        }
      ],
      "props": {
        "optionType": "button",
        "buttonStyle": "solid"
      }
    }
  ]
