  "name": "1",
  "role": "admin",
  "age": 18,
  "email": "alice@example.com",
  "birthday": "2005-05-20",
  "active": true,
  "bio": "A long bio that will be rendered as a textarea...",
  "gender": "female",
  "__form": {
    "auth": {
      "bearer": "{{token}}"
    },
    "submit": [
      {
        "label": "保存",
        "url": "https://httpbin.org/anything/{{name}}",
        "method": "POST",
        "headers": {
          "X-Source": "json-render"
        },
        "query": {
          "role": "{{role}}"
        },
        "body": {
          "$formConfig": true,
          "id": "1",
          "active": true,
          "bio": "A long bio that will be rendered as a textarea because its length exceeds the threshold used by the form view. Edit freely."
        },
        "requiredPaths": [
          "name",
          "email"
        ],
        "responsePath": "lastResponse",
        "variant": "primary",
        "timeoutMs": 5000,
        "openUrl": "{{lastResponse.redirect}}"
      },
      {
        "label": "Save Draft",
        "url": "https://httpbin.org/anything",
        "method": "PUT",
        "variant": "secondary",
        "bodyPath": "name"
      },
      {
        "label": "Slow (6s, will timeout)",
        "url": "https://httpbin.org/delay/6",
        "method": "POST",
        "timeoutMs": 2000,
        "variant": "secondary",
        "body": {}
      },
      {
        "label": "Force 500",
        "url": "https://httpbin.org/status/500",
        "method": "POST",
        "variant": "secondary",
        "body": {}
      },
      {
        "label": "Upload file",
        "url": "https://httpbin.org/anything",
        "method": "POST",
        "body": {
          "note": "{{name}}'s avatar",
          "tag": "profile",
          "avatar": {
            "$file": "./sample-avatar.txt",
            "filename": "avatar.txt",
            "contentType": "text/plain"
          }
        },
        "responsePath": "lastUpload",
        "variant": "primary"
      },
      {
        "type": "reset",
        "label": "Reset",
        "variant": "secondary",
        "confirm": "Reset all fields to initial values?"
      },
      {
        "label": "Delete",
        "url": "https://httpbin.org/anything",
        "method": "DELETE",
        "variant": "danger",
        "confirm": "Delete this record?",
        "body": {}
      }
    ]
  },
  "formConfig": [
    {
      "label": "用户名称",
      "keyName": "name",
      "keyValue": "Alice",
      "component": "Input",
      "col": {
