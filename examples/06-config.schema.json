
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "App Config",
  "type": "object",
  "required": ["appName", "environment", "port"],
  "properties": {
    "appName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Application display name."
    },
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Runtime environment."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "HTTP port the server listens on."
    },
    "debug": {
      "type": "boolean",
      "description": "Enable verbose debug logging."
    },
    "logLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"],
      "description": "Minimum log level to emit."
    },
    "database": {
      "type": "object",
      "required": ["host", "port", "name"],
      "description": "Primary database connection.",
      "properties": {
        "host": { "type": "string", "description": "DB host / IP" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "name": { "type": "string", "description": "Database name" },
        "ssl":  { "type": "boolean", "description": "Use TLS connection" }
      }
    },
    "features": {
      "type": "object",
      "description": "Feature toggles.",
      "properties": {
        "enableAnalytics": { "type": "boolean" },
        "enableBetaUI":    { "type": "boolean" },
        "maxUploadMB":     { "type": "integer", "minimum": 1, "maximum": 1024 }
      }
    },
    "allowedOrigins": {
      "type": "array",
      "description": "CORS whitelist.",
      "items": { "type": "string", "format": "uri" }
    }
  }
}
